# Copy this file to .env locally, or set these as environment variables
# in the Railway dashboard (Project -> Variables). NEVER commit real keys.

# Google AI Studio -> https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-2.0-flash

# ElevenLabs -> https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your_elevenlabs_key_here
# Pick any voice id from your ElevenLabs "Voices" tab
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5

# Solana devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
# Public key that receives tips (any devnet keypair address you control)
SOLANA_RECEIVER_ADDRESS=your_devnet_public_key_here

PORT=3000
